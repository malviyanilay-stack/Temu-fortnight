<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Temu Fortnite</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <script src="https://cdn.socket.io/4.7.2/socket.io.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <style>
        body { margin: 0; overflow: hidden; background-color: #000; font-family: sans-serif; touch-action: none; }
        #ui { position: absolute; width: 100%; height: 100%; pointer-events: none; z-index: 10; }
        .hud { position: absolute; background: rgba(0,0,0,0.8); color: #fff; padding: 12px; border: 2px solid #ff4444; }
        #health-ui { top: 20px; left: 20px; width: 200px; }
        #health-bar { width: 100%; height: 20px; background: #ff4444; transition: width 0.1s; }
        .bar-bg { width: 100%; height: 20px; background: #222; margin-top: 5px; border: 1px solid #555; }
        #stats { top: 20px; right: 20px; text-align: right; color: #0ff; border: 1px solid #0ff; padding: 5px; }
        #btns { position: absolute; bottom: 30px; right: 20px; display: flex; flex-direction: column; gap: 15px; pointer-events: auto; }
        .btn { width: 80px; height: 80px; background: rgba(20,20,20,0.8); color: white; border: 3px solid #0ff; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: bold; }
        #fire-btn { background: #ff4444; width: 100px; height: 100px; }
        #joystick-ui { position: absolute; bottom: 50px; left: 50px; width: 140px; height: 140px; background: rgba(0,255,255,0.1); border: 2px solid #0ff; border-radius: 50%; pointer-events: auto; }
        #joystick-knob { position: absolute; width: 60px; height: 60px; background: #0ff; border-radius: 50%; left: 40px; top: 40px; }
    </style>
</head>
<body>
    <div id="ui">
        <div id="health-ui" class="hud">HEALTH<div class="bar-bg"><div id="health-bar"></div></div></div>
        <div id="stats">ELIMS: <span id="elim-count">0</span> | ENEMIES: <span id="enemy-count">0</span></div>
        <div id="joystick-ui"><div id="joystick-knob"></div></div>
        <div id="btns"><div id="fire-btn" class="btn">FIRE</div><div id="jump-btn" class="btn">JUMP</div></div>
    </div>

    <script>
        const socket = io("https://temu-fortnight2.onrender.com");
        const scene = new THREE.Scene();
        scene.background = new THREE.Color(0x87ceeb);
        const camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
        const renderer = new THREE.WebGLRenderer({ antialias: true });
        renderer.setSize(window.innerWidth, window.innerHeight);
        document.body.appendChild(renderer.domElement);

        const sun = new THREE.DirectionalLight(0xffffff, 1);
        sun.position.set(10, 20, 10);
        scene.add(sun);
        scene.add(new THREE.AmbientLight(0x404040));

        // --- Grass & Trees ---
        const floor = new THREE.Mesh(new THREE.PlaneGeometry(200, 200), new THREE.MeshStandardMaterial({ color: 0x2e7d32 }));
        floor.rotation.x = -Math.PI / 2;
        scene.add(floor);

        // --- Player & Enemy Creator ---
        function createModel(isEnemy = false) {
            const group = new THREE.Group();
            const color = isEnemy ? 0xff0000 : 0x00ff00;
            const body = new THREE.Mesh(new THREE.BoxGeometry(0.8, 1.2, 0.4), new THREE.MeshStandardMaterial({color}));
            const head = new THREE.Mesh(new THREE.BoxGeometry(0.5, 0.5, 0.5), new THREE.MeshStandardMaterial({color: 0xffdbac}));
            head.position.y = 1;
            group.add(body, head);
            group.userData.originalColor = color;
            return group;
        }

        const localPlayer = createModel(false);
        scene.add(localPlayer);
        const enemies = {};
        let elims = 0;

        // --- Shift Lock & Movement ---
        let joyPos = { x: 0, y: 0 };
        document.getElementById('joystick-ui').addEventListener('touchmove', (e) => {
            const t = e.touches[0]; const r = e.currentTarget.getBoundingClientRect();
            joyPos.x = (t.clientX - (r.left + r.width/2))/70; joyPos.y = (t.clientY - (r.top + r.height/2))/70;
        });
        document.getElementById('joystick-ui').addEventListener('touchend', () => joyPos = {x:0, y:0});

        // --- Damage Effect ---
        function flashRed(mesh) {
            mesh.children.forEach(child => {
                if(child.material) {
                    gsap.to(child.material.color, { r: 1, g: 0, b: 0, duration: 0.1 });
                    gsap.to(child.material.color, { 
                        r: mesh.userData.originalColor ? ((mesh.userData.originalColor >> 16) & 255) / 255 : 1, 
                        g: mesh.userData.originalColor ? ((mesh.userData.originalColor >> 8) & 255) / 255 : 1, 
                        b: mesh.userData.originalColor ? (mesh.userData.originalColor & 255) / 255 : 1, 
                        delay: 0.3, duration: 0.1 
                    });
                }
            });
        }

        // --- Combat ---
        document.getElementById('fire-btn').addEventListener('touchstart', () => {
            // "Punch" animation
            gsap.to(localPlayer.position, { z: localPlayer.position.z - 1, duration: 0.1, yoyo: true, repeat: 1 });
            
            Object.keys(enemies).forEach(id => {
                if(localPlayer.position.distanceTo(enemies[id].position) < 5) {
                    flashRed(enemies[id]);
                    socket.emit('enemyDied', id);
                    elims++;
                    document.getElementById('elim-count').innerText = elims;
                }
            });
        });

        // --- Online Enemies ---
        socket.on('spawnEnemy', (data) => {
            const enemy = createModel(true);
            enemy.position.set(data.x, 0.6, data.z);
            scene.add(enemy);
            enemies[data.id] = enemy;
            document.getElementById('enemy-count').innerText = Object.keys(enemies).length;
        });

        socket.on('removeEnemy', (id) => {
            if(enemies[id]) { scene.remove(enemies[id]); delete enemies[id]; }
        });

        function animate() {
            requestAnimationFrame(animate);
            
            // Movement + Shift Lock
            if(Math.abs(joyPos.x) > 0.1 || Math.abs(joyPos.y) > 0.1) {
                localPlayer.position.x += joyPos.x * 0.15;
                localPlayer.position.z += joyPos.y * 0.15;
                // Shift Lock: Turn body toward movement direction
                localPlayer.rotation.y = Math.atan2(joyPos.x, joyPos.y);
            }

            camera.position.set(localPlayer.position.x, 6, localPlayer.position.z + 10);
            camera.lookAt(localPlayer.position);

            socket.emit('playerMovement', { x: localPlayer.position.x, y: 0, z: localPlayer.position.z, yaw: localPlayer.rotation.y });
            renderer.render(scene, camera);
        }
        animate();
    </script>
</body>
</html>
